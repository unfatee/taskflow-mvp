# URL входящего webhook Bitrix24 с правом CRM.
# Формат 1: https://example.bitrix24.ru/rest/1/webhook_code/
# Формат 2: https://example.bitrix24.ru/rest/1/webhook_code/crm.deal.add.json
# Секретный webhook нельзя хранить в GitHub. Добавьте его в Vercel Environment Variables.
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your_webhook_code/

# true включает тестовый ответ без обращения к Bitrix24.
# Для реальной API-интеграции установите false и добавьте BITRIX24_WEBHOOK_URL.
CRM_MOCK_MODE=false

# Коды пользовательских полей Bitrix24 уже зашиты в api/crm/create-deal.js:
# Описание задачи: UF_CRM_1777804608701
# Дедлайн задачи: UF_CRM_1777804782669
# Приоритет задачи: UF_CRM_1777804868815, значения High=44, Medium=46, Low=48
# Категория задачи: UF_CRM_1777804887989
# Статус задачи: UF_CRM_1777804927342, значения new=50, in_progress=52, done=54
# Дата создания в приложении: UF_CRM_1777804943652
# Источник заявки: UF_CRM_1777804958149
